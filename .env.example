# Copy to .env and fill in real values. Never commit .env.

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092   # inside Docker network
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092  # from host machine

# ── SEC EDGAR ─────────────────────────────────────────────────────────────────
# Required by SEC fair-use policy: "CompanyName contact@email.com"
EDGAR_USER_AGENT=EarningsSentimentResearch contact@example.com

# ── Ingestor ──────────────────────────────────────────────────────────────────
# Comma-separated list of tickers to watch (start small, expand later)
TICKERS=AAPL,MSFT,GOOGL,AMZN,META,NVDA,TSLA,JPM,JNJ,XOM
LOOKBACK_DAYS=30      # how far back to scan for filings on first run
SCHEDULE_HOUR=6       # UTC hour for the daily cron

# ── Financial Modeling Prep (FMP) ────────────────────────────────────────────
# Fallback transcript source for tickers not found on EDGAR.
# Free tier available at https://financialmodelingprep.com/developer/docs
# Leave blank to disable FMP fallback.
FMP_API_KEY=

# ── Claude / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Correlation service ───────────────────────────────────────────────────────
# Calendar days to fetch beyond the 7d window to absorb weekends + holidays.
PRICE_FETCH_DAYS=12

# ── BFF ───────────────────────────────────────────────────────────────────────
JWT_SECRET=changeme
PORT=3001

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
