# Copy to .env and fill in real values. Never commit .env.

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092   # inside Docker network
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092  # from host machine

# ── SEC EDGAR ─────────────────────────────────────────────────────────────────
# Required by SEC fair-use policy: "CompanyName contact@email.com"
EDGAR_USER_AGENT=EarningsSentimentResearch contact@example.com

# ── Ingestor ──────────────────────────────────────────────────────────────────
# Comma-separated list of tickers for the per-ticker backfill scan.
# The RSS feed (below) provides universal coverage of ALL listed companies.
TICKERS=AAPL,MSFT,GOOGL,AMZN,META,NVDA,TSLA,JPM,JNJ,XOM
LOOKBACK_DAYS=30              # how far back to scan for filings on first run
SCHEDULE_INTERVAL_HOURS=2     # how often to run per-ticker backfill (min 2 on FMP free tier)
RSS_POLL_INTERVAL_MINUTES=10  # how often to poll EDGAR live 8-K feed (all public companies)

# ── Financial Modeling Prep (FMP) ────────────────────────────────────────────
# Fallback transcript source for tickers not found on EDGAR.
# Free tier: https://financialmodelingprep.com/developer/docs
# Leave blank to disable FMP fallback.
FMP_API_KEY=

# ── Claude / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
SCORING_MODEL=claude-haiku-4-5-20251001
# INSPECT_MODEL=claude-sonnet-4-6  # default; leave unset for best quality

# ── Correlation service ───────────────────────────────────────────────────────
PRICE_FETCH_DAYS=12

# ── BFF ───────────────────────────────────────────────────────────────────────
# IMPORTANT: JWT_SECRET must be DIFFERENT from MONGO_ROOT_PASSWORD.
# Generate a strong, unique value: openssl rand -base64 32
JWT_SECRET=changeme_use_a_strong_random_secret_here
PORT=3001

# ── Notifications (Resend) ────────────────────────────────────────────────────
# Free tier: 3,000 emails/month — https://resend.com
NOTIFICATION_PROVIDER=none
RESEND_API_KEY=
APP_URL=http://localhost:3000
# NOTIFY_FROM_EMAIL=EarningsSentiment <notifications@yourdomain.com>

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── BFF CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
